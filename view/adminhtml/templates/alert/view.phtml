 */

$alert = $block->getAlert();
$product = $block->getProduct();
$currentPrice = $block->getCurrentProductPrice();
$targetPrice = (float) $alert->getTargetPrice();
$subscribedPrice = (float) $alert->getSubscribedPrice();
$priceReached = $targetPrice > 0 && $currentPrice > 0 && $currentPrice <= $targetPrice;
?>

<div class="admin__page-section" style="margin-bottom: 2rem;">
    <div class="admin__page-section-title" style="display:flex; justify-content:space-between; align-items:center;">
        <span class="title"><?= $block->escapeHtml(__('Price Alert #%1', $alert->getId())) ?></span>
        <div class="page-actions-buttons" style="display:flex; gap:0.5rem;">
            <button type="button" class="action-default scalable back"
                    onclick="setLocation('<?= $block->escapeUrl($block->getBackUrl()) ?>')">
                <span><?= $block->escapeHtml(__('Back')) ?></span>
            </button>
            <button type="button" class="action-default scalable save primary"
                    onclick="confirmSetLocation('<?= $block->escapeJs(__('Send price drop notification email to this customer?')) ?>', '<?= $block->escapeUrl($block->getSendEmailUrl()) ?>')">
                <span><?= $block->escapeHtml(__('Send Email')) ?></span>
            </button>
            <button type="button" class="action-default scalable delete"
                    onclick="confirmSetLocation('<?= $block->escapeJs(__('Are you sure you want to delete this alert?')) ?>', '<?= $block->escapeUrl($block->getDeleteUrl()) ?>')">
                <span><?= $block->escapeHtml(__('Delete')) ?></span>
            </button>
        </div>
    </div>
    <div class="admin__page-section-content">
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:2rem;">

            <!-- Alert Details -->
            <fieldset class="admin__fieldset">
                <legend class="admin__legend"><span><?= $block->escapeHtml(__('Subscription Details')) ?></span></legend>
                <br/>
                <table class="admin__table-secondary">
                    <tr>
                        <th><?= $block->escapeHtml(__('Alert ID')) ?></th>
                        <td>#<?= $block->escapeHtml($alert->getId()) ?></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Status')) ?></th>
                        <td>
                            <?php
                            $status = (int) $alert->getStatus();
                            if ($status === \Panth\PriceDropAlert\Model\PriceAlert::STATUS_ACTIVE) {
                                echo '<span class="grid-severity-notice"><span>' . $block->escapeHtml(__('Active')) . '</span></span>';
                            } elseif ($status === \Panth\PriceDropAlert\Model\PriceAlert::STATUS_SENT) {
                                echo '<span class="grid-severity-minor"><span>' . $block->escapeHtml(__('Sent')) . '</span></span>';
                            } elseif ($status === \Panth\PriceDropAlert\Model\PriceAlert::STATUS_CANCELLED) {
                                echo '<span class="grid-severity-critical"><span>' . $block->escapeHtml(__('Cancelled')) . '</span></span>';
                            }
                            ?>
                        </td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Customer Name')) ?></th>
                        <td><?= $block->escapeHtml($alert->getCustomerName() ?: __('N/A')) ?></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Email')) ?></th>
                        <td><a href="mailto:<?= $block->escapeHtmlAttr($block->getCustomerEmail()) ?>"><?= $block->escapeHtml($block->getCustomerEmail()) ?></a></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Customer Type')) ?></th>
                        <td><?= $alert->getCustomerId() ? $block->escapeHtml(__('Registered (ID: %1)', $alert->getCustomerId())) : $block->escapeHtml(__('Guest')) ?></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Subscribed At')) ?></th>
                        <td><?= $block->escapeHtml($block->formatDate($alert->getCreatedAt(), \IntlDateFormatter::MEDIUM, true)) ?></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Email Sent At')) ?></th>
                        <td><?= $alert->getSentAt() ? $block->escapeHtml($block->formatDate($alert->getSentAt(), \IntlDateFormatter::MEDIUM, true)) : '<em>' . $block->escapeHtml(__('Not sent yet')) . '</em>' ?></td>
                    </tr>
                </table>
            </fieldset>

            <!-- Product & Price Details -->
            <fieldset class="admin__fieldset">
                <legend class="admin__legend"><span><?= $block->escapeHtml(__('Product & Price Details')) ?></span></legend>
                <br/>
                <?php if ($product): ?>
                <table class="admin__table-secondary">
                    <tr>
                        <th><?= $block->escapeHtml(__('Product')) ?></th>
                        <td>
                            <a href="<?= $block->escapeUrl($block->getUrl('catalog/product/edit', ['id' => $product->getId()])) ?>">
                                <?= $block->escapeHtml($product->getName()) ?>
                            </a>
                            <br/><small style="color:#999;">ID: <?= $block->escapeHtml($product->getId()) ?> | SKU: <?= $block->escapeHtml($product->getSku()) ?> | <?= $block->escapeHtml(ucfirst($product->getTypeId())) ?></small>
                        </td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Price When Subscribed')) ?></th>
                        <td><strong><?= $block->escapeHtml($block->formatPrice($subscribedPrice)) ?></strong></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Target Price')) ?></th>
                        <td><strong style="color:#eb5202;"><?= $targetPrice > 0 ? $block->escapeHtml($block->formatPrice($targetPrice)) : $block->escapeHtml(__('Any price drop')) ?></strong></td>
                    </tr>
                    <tr>
                        <th><?= $block->escapeHtml(__('Current Price')) ?></th>
                        <td><strong style="font-size:1.25em;"><?= $block->escapeHtml($block->formatPrice($currentPrice)) ?></strong></td>
                    </tr>
                </table>

                <!-- Price Status Message -->
                <?php if ($targetPrice > 0 && $currentPrice > 0): ?>
                    <?php if ($priceReached): ?>
                    <div class="message message-success" style="margin-top:1.5rem;">
                        <?= $block->escapeHtml(__('Target price reached! The current price of %1 has met or dropped below the target of %2. You can send the notification email now.', $block->formatPrice($currentPrice), $block->formatPrice($targetPrice))) ?>
                    </div>
                    <?php else: ?>
                    <div class="message message-info" style="margin-top:1.5rem;">
                        <?php $diff = $currentPrice - $targetPrice; ?>
                        <?= $block->escapeHtml(__('Waiting for price drop. The price needs to decrease by %1 to reach the target of %2.', $block->formatPrice($diff), $block->formatPrice($targetPrice))) ?>
                    </div>
                    <?php endif; ?>
                <?php elseif ($subscribedPrice > 0 && $currentPrice > 0 && $currentPrice < $subscribedPrice): ?>
                    <div class="message message-success" style="margin-top:1.5rem;">
                        <?php $savings = $subscribedPrice - $currentPrice; ?>
                        <?= $block->escapeHtml(__('Price has dropped! The product was %1 when subscribed and is now %2 (saving %3). You can send the notification email now.', $block->formatPrice($subscribedPrice), $block->formatPrice($currentPrice), $block->formatPrice($savings))) ?>
                    </div>
                <?php endif; ?>

                <?php else: ?>
                <div class="message message-warning">
                    <?= $block->escapeHtml(__('Product not found or has been deleted.')) ?>
                </div>
                <?php endif; ?>
            </fieldset>
        </div>
    </div>
</div>
