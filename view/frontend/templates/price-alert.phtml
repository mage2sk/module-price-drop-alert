<script>
document.addEventListener('alpine:init', () => {
    Alpine.data('priceAlertComponent', (productId, currentPrice, customerEmail, customerName, isLoggedIn) => ({
        productId, currentPrice, email: customerEmail, customerName, isLoggedIn,
        targetPrice: '', loading: true, subscribed: false, submitting: false,
        alertData: null, showForm: false,
        notification: { show: false, message: '', type: 'success' },
        init() {
            // Detect logged-in customer via Magento section data (FPC compatible)
            try {
                const sections = JSON.parse(localStorage.getItem('mage-cache-storage') || '{}');
                if (sections.customer && sections.customer.firstname) {
                    this.isLoggedIn = true;
                    this.customerName = sections.customer.firstname + (sections.customer.lastname ? ' ' + sections.customer.lastname : '');
                    if (sections.customer.email) this.email = sections.customer.email;
                }
            } catch (e) {}

            // If logged in but no email, fetch via AJAX
            if (this.isLoggedIn && !this.email) {
                fetch('/customer/section/load/?sections=customer', { credentials: 'include' })
                    .then(r => r.json())
                    .then(data => {
                        if (data.customer && data.customer.email) this.email = data.customer.email;
                        if (data.customer && data.customer.firstname && !this.customerName) {
                            this.customerName = data.customer.firstname + (data.customer.lastname ? ' ' + data.customer.lastname : '');
                        }
                    }).catch(() => {});
            }

            this.checkStatus();
        },
        async checkStatus() {
            this.loading = true;
            try {
                const url = new URL('<?= $escaper->escapeUrl($block->getStatusUrl()) ?>');
                url.searchParams.append('product_id', this.productId);
                if (this.email) url.searchParams.append('email', this.email);
                const data = await (await fetch(url)).json();
                this.subscribed = data.subscribed || false;
                this.alertData = data.alert || null;
                this.showForm = !this.subscribed;
            } catch (e) { this.showForm = true; } finally { this.loading = false; }
        },
        async subscribe() {
            if (!this.isLoggedIn && (!this.customerName || !this.customerName.trim()))
                return this.showNotification('Please enter your name', 'error');
            if (!this.isLoggedIn && (!this.email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(this.email)))
                return this.showNotification('Please enter a valid email address', 'error');
            if (this.targetPrice && parseFloat(this.targetPrice) >= this.currentPrice)
                return this.showNotification('Target price must be lower than current price', 'error');
            this.submitting = true;
            try {
                const fd = new FormData();
                fd.append('product_id', this.productId);
                if (!this.isLoggedIn) { fd.append('email', this.email); fd.append('customer_name', this.customerName); }
                else if (this.customerName?.trim()) fd.append('customer_name', this.customerName);
                if (this.targetPrice) fd.append('trigger_price', this.targetPrice);
                fd.append('form_key', hyva.getFormKey());
                const data = await (await fetch('<?= $escaper->escapeUrl($block->getSubscribeUrl()) ?>', { method: 'POST', body: fd })).json();
                if (data.success) { this.showNotification(data.message || 'Subscribed!', 'success'); this.subscribed = true; this.targetPrice = ''; await this.checkStatus(); }
                else this.showNotification(data.message || 'Failed', 'error');
            } catch (e) { this.showNotification('An error occurred.', 'error'); } finally { this.submitting = false; }
        },
        async unsubscribe() {
            this.submitting = true;
            try {
                const fd = new FormData();
                fd.append('product_id', this.productId);
                if (!this.isLoggedIn) fd.append('email', this.email);
                fd.append('form_key', hyva.getFormKey());
                const data = await (await fetch('<?= $escaper->escapeUrl($block->getUnsubscribeUrl()) ?>', { method: 'POST', body: fd })).json();
                if (data.success) { this.showNotification('Unsubscribed', 'success'); this.subscribed = false; this.alertData = null; this.showForm = true; }
                else this.showNotification(data.message || 'Failed', 'error');
            } catch (e) { this.showNotification('An error occurred.', 'error'); } finally { this.submitting = false; }
        },
        formatPrice(p) { return <?= /* @noEscape */ json_encode($currencySymbol, JSON_HEX_TAG | JSON_HEX_AMP | JSON_HEX_APOS | JSON_HEX_QUOT) ?> + parseFloat(p).toFixed(2); },
        showNotification(message, type) { this.notification = { show: true, message, type }; setTimeout(() => { this.notification.show = false; }, 5000); }
    }));
});
</script>
