                        <input type="number" id="<?= $escaper->escapeHtmlAttr($uid) ?>-target" step="0.01" min="0.01" max="<?= (float)$currentPrice - 0.01 ?>" placeholder="<?= $escaper->escapeHtmlAttr(number_format($currentPrice * 0.9, 2)) ?>">
