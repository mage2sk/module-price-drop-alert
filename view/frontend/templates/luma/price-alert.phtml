                    <input type="email" id="<?= $escaper->escapeHtmlAttr($uid) ?>-email" placeholder="<?= $escaper->escapeHtmlAttr(__('you@example.com')) ?>" value="<?= $escaper->escapeHtmlAttr($customerEmail ?: '') ?>">
