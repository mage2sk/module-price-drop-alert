<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <!-- Data Provider for Alert Listing Grid -->
    <virtualType name="Panth\PriceDropAlert\Ui\DataProvider\AlertGridDataProvider" type="Magento\Framework\View\Element\UiComponent\DataProvider\DataProvider">
        <arguments>
            <argument name="collection" xsi:type="object" shared="false">Panth\PriceDropAlert\Model\ResourceModel\PriceAlert\Collection</argument>
            <argument name="filterPool" xsi:type="object" shared="false">PriceAlertGridFilterPool</argument>
        </arguments>
    </virtualType>

    <virtualType name="PriceAlertGridFilterPool" type="Magento\Framework\View\Element\UiComponent\DataProvider\FilterPool">
        <arguments>
            <argument name="appliers" xsi:type="array">
                <item name="regular" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\RegularFilter</item>
                <item name="fulltext" xsi:type="object">Magento\Framework\View\Element\UiComponent\DataProvider\FulltextFilter</item>
            </argument>
        </arguments>
    </virtualType>

    <type name="Magento\Framework\View\Element\UiComponent\DataProvider\CollectionFactory">
        <arguments>
            <argument name="collections" xsi:type="array">
                <item name="pricedropalert_alert_listing_data_source" xsi:type="string">Panth\PriceDropAlert\Model\ResourceModel\PriceAlert\Grid\Collection</item>
            </argument>
        </arguments>
    </type>

    <virtualType name="Panth\PriceDropAlert\Model\ResourceModel\PriceAlert\Grid\Collection" type="Magento\Framework\View\Element\UiComponent\DataProvider\SearchResult">
        <arguments>
            <argument name="mainTable" xsi:type="string">panth_price_alert</argument>
            <argument name="resourceModel" xsi:type="string">Panth\PriceDropAlert\Model\ResourceModel\PriceAlert</argument>
        </arguments>
    </virtualType>
</config>
