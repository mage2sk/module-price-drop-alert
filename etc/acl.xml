<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Acl/etc/acl.xsd">
    <acl>
        <resources>
            <resource id="Magento_Backend::admin">
                <resource id="Panth_PriceDropAlert::panth_pricedropalert" title="Price Drop Alert" sortOrder="200">
                    <resource id="Panth_PriceDropAlert::dashboard" title="Dashboard" sortOrder="10"/>
                    <resource id="Panth_PriceDropAlert::alerts" title="Manage Alerts" sortOrder="20">
                        <resource id="Panth_PriceDropAlert::alert_view" title="View Alert" sortOrder="10"/>
                        <resource id="Panth_PriceDropAlert::alert_delete" title="Delete Alert" sortOrder="20"/>
                        <resource id="Panth_PriceDropAlert::alert_send" title="Send Alert Email" sortOrder="30"/>
                    </resource>
                    <resource id="Panth_PriceDropAlert::config" title="Configuration" sortOrder="100"/>
                </resource>
            </resource>
        </resources>
    </acl>
</config>
